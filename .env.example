# ── Server-only env (NEVER prefixed NEXT_PUBLIC_; never sent to the browser) ──
# Read only by the BFF proxy route handler (src/app/api/[...path]/route.ts).
# There is NO TENANT_KEY — the JWT cookie carries tenant identity.
API_BASE_URL=https://employee-management-system-2b9q.onrender.com/api/v1

# ── Public env (exposed to the browser). Never put secrets here. ──
NEXT_PUBLIC_USE_MOCKS=true
NEXT_PUBLIC_APP_URL=http://localhost:3000
