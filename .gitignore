# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real secrets; explicitly allow the example template
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Project-specific
.env.local
.env.*.local
.vercel
coverage/
playwright-report/
test-results/

# Claude Code — local settings contain machine-specific permission rules, not secrets,
# but must not be committed (gitignored per security gate B2).
.claude/settings.local.json

# graphify — local knowledge-graph build output (~8 MB, machine-local, regenerated
# on demand via the /graphify skill). Not pushed.
graphify-out/

# superpowers — local brainstorm/process scratch. Conclusions get promoted to docs/
# or memory; the raw sessions stay machine-local. Not pushed.
.superpowers/
